{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/tbhd-sidecar",
          "sidecar": true,
          "args": [
            "-s", "main.py",
            "--set", "upstream_cert=false",
            "-p", { "validator": "\\d+" }
          ]
        }
      ]
    },
    "shell:allow-kill"
  ]
}
