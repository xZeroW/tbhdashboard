# Maintainer: xZeroW

pkgname=tbhdashboard-git-local
_pkgname=tbhdashboard
pkgver=0.1.8
pkgrel=1
pkgdesc="Native Arch package for TaskBarHero Dashboard built from the local checkout"
arch=('x86_64')
url="https://github.com/xZeroW/tbhdashboard"
license=('unknown')
depends=(
  'gtk3'
  'hicolor-icon-theme'
  'libayatana-appindicator'
  'openssl'
  'webkit2gtk-4.1'
)
makedepends=(
  'cargo'
  'cargo-tauri'
  'rust'
  'trunk'
)
source=()

prepare() {
  local project_root
  project_root="$(realpath "$startdir/../..")"

  rm -rf "$srcdir/$_pkgname"
  mkdir -p "$srcdir/$_pkgname"

  bsdtar \
    --exclude='./.git' \
    --exclude='./Assets' \
    --exclude='./dist' \
    --exclude='./target' \
    --exclude='./src-tauri/target' \
    --exclude='./sidecar/dist' \
    --exclude='./packaging/arch/pkg' \
    --exclude='./packaging/arch/src' \
    -cf - -C "$project_root" . | bsdtar -xf - -C "$srcdir/$_pkgname"
}

build() {
  cd "$srcdir/$_pkgname"

  # makepkg injects -flto=auto into CFLAGS/CXXFLAGS, which breaks native C
  # static crates (aws-lc-sys, ring, zstd-sys) when linked into Rust.
  # Strip LTO flags for the Cargo build only.
  export CFLAGS="${CFLAGS/-flto=auto/}"
  export CXXFLAGS="${CXXFLAGS/-flto=auto/}"

  # Proxy is embedded in the main binary (commit 00be653). No sidecar binary needed.

  # Build WASM frontend with explicit --release; under makepkg trunk build
  # without --release unexpectedly defaults to dev profile.
  #
  # wasm-opt (binaryen v123) needs --enable-bulk-memory &
  # --enable-sign-ext for newer Rust WASM output.  Trunk doesn't expose
  # wasm-opt feature flags, so we run trunk twice: the first run downloads
  # wasm-opt and compiles everything (but fails at wasm-opt validation),
  # then we wrap wasm-opt and re-run trunk to finish successfully.
  rm -rf ~/.cache/trunk
  trunk build --release 2>/dev/null || true

  local wasm_opt_bin
  wasm_opt_bin="$(find ~/.cache/trunk -name wasm-opt -type f 2>/dev/null | head -1)"
  if [ -n "$wasm_opt_bin" ] && [ ! -f "${wasm_opt_bin}.real" ]; then
    mv "$wasm_opt_bin" "${wasm_opt_bin}.real"
    cat > "$wasm_opt_bin" << 'WRAPPER'
#!/bin/bash
exec "$(dirname "$0")/wasm-opt.real" \
  --enable-bulk-memory --enable-bulk-memory-opt \
  --enable-sign-ext --enable-nontrapping-float-to-int "$@"
WRAPPER
    chmod +x "$wasm_opt_bin"
  fi

  rm -rf dist
  trunk build --release

  # Prevent cargo tauri build from re-running trunk build (which lacks --release)
  sed -i 's/"beforeBuildCommand": "trunk build"/"beforeBuildCommand": ""/' src-tauri/tauri.conf.json

  # sidecar was removed in commit 00be653; proxy is now embedded in main binary.
  cargo tauri build --no-bundle --ci
}

package() {
  cd "$srcdir/$_pkgname"

  install -Dm755 "target/release/tbhdashboard" "$pkgdir/usr/bin/TaskBarHeroDashboard"
  install -Dm644 "src-tauri/icons/128x128.png" "$pkgdir/usr/share/icons/hicolor/128x128/apps/tbhdashboard.png"

  install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/tbhdashboard.desktop" <<'EOF'
[Desktop Entry]
Type=Application
Name=TaskBarHero Dashboard
Comment=Read-only dashboard for TaskBarHero chest queues and farming data
Exec=TaskBarHeroDashboard
Icon=tbhdashboard
Terminal=false
Categories=Game;
StartupWMClass=TaskBarHeroDashboard
EOF
}
